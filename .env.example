ANTHROPIC_API_KEY=your_key_here
# Leave commented for local SQLite. Uncomment and set for Neon PostgreSQL:
# DATABASE_URL=postgresql://user:password@host/dbname
# Model: claude-haiku-4-5-20251001 (fast/cheap) or claude-sonnet-4-20250514 (production)
CLAUDE_MODEL=claude-haiku-4-5-20251001
PORT=8000
ENV=development
# Demo user (auto-seeded at startup) — read-only when READ_ONLY=true
DEMO_USERNAME=demo
DEMO_PASSWORD=demo2026
DEMO_DISPLAY_NAME=Demo User
DEMO_ROLE=Finance Operations · Demo Account
# Admin user (auto-seeded at startup) — bypasses READ_ONLY restrictions
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=Admin
ADMIN_ROLE=Owner
# Set READ_ONLY=true for public deployments — disables uploads + rule edits for non-admins
READ_ONLY=false
